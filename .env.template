# Copie este arquivo para .env e preencha com suas credenciais
# Nunca commite .env no repositório!

# ─── Banco de Dados ───
# Ajuste conforme seu ambiente
# Docker: postgresql://postgres:postgres@postgres:5432/wpp_agent
# Local: postgresql://user:pass@localhost:5432/wpp_agent
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wpp_agent?schema=public"

# ─── WhatsApp Cloud API (Meta) ───

# Token de acesso da API Graph (obrigatório)
# Gerado em: https://developers.facebook.com/apps/{app-id}/settings/basic
# Formato: Long-lived token (60 dias) ou permanente
# Exemplo: EAATZBaURG4hMBQtzAZBWeldd0WLeuLOB1PaZB18USZCm9MZ...
WHATSAPP_API_TOKEN="EAA..."

# ID do número de telefone WhatsApp (obrigatório)
# Obtém em: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# Formato: Apenas números, sem sinais (ex: 983563674841785)
# Dica: Este é o phone_number_id, não é o número de telefone do cliente
WHATSAPP_PHONE_NUMBER_ID="983563674841785"

# Token para validação do webhook (obrigatório)
# Você escolhe qualquer string (recomendado: gerar com openssl ou uuid)
# Deve ser IDÊNTICO ao registrado no dashboard Meta
# Exemplo: openssl rand -hex 16
WHATSAPP_VERIFY_TOKEN="meu_webhook_token_super_seguro_abc123xyz"

# Segredo da aplicação (opcional, para validar assinatura HMAC)
# Gerado em: https://developers.facebook.com/apps/{app-id}/settings/basic
# Se deixado vazio, validação de assinatura é saltada (OK para teste)
# Formato: string hexadecimal de ~32 caracteres
WHATSAPP_APP_SECRET="abc123def456abc123def456abc123"

# Versão da API Graph (opcional, padrão: v18.0)
# Alterar apenas se Meta descontinuar versão antiga
WHATSAPP_API_VERSION="v18.0"

# ─── Ambiente ───
# development | production
NODE_ENV="development"
