# ─── Banco de Dados ───
# PostgreSQL connection string for Prisma
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wpp_agent?schema=public"

# ─── WhatsApp Cloud API (Meta) ───
# Obrigatório: Token de verificação do webhook (escolha uma string qualquer para teste)
WHATSAPP_VERIFY_TOKEN="seu_webhook_verify_token_aqui"

# Obrigatório: Token de acesso da API (Graph API token)
# Gerado em: https://developers.facebook.com/apps/{app-id}/settings/basic
WHATSAPP_API_TOKEN="seu_token_da_api_aqui"

# Obrigatório: ID do número de telefone WhatsApp
# Obtém em: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# Exemplo: 983563674841785
WHATSAPP_PHONE_NUMBER_ID="seu_phone_number_id_aqui"

# Opcional: Segredo da aplicação (para validar assinatura do webhook)
# Gerado em: https://developers.facebook.com/apps/{app-id}/settings/basic
WHATSAPP_APP_SECRET=""

# Opcional: Versão da API Graph (padrão: v18.0)
WHATSAPP_API_VERSION="v18.0"

# ─── AI (Openrouter) ───
# Obrigatório: Chave da API OpenRouter
OPENROUTER_API_KEY="sua_chave_openrouter_aqui"

# ─── Limites de Testes (Test Harness) ───
# Limite maximo de palavras por mensagem do agente (por intent)
MAX_AGENT_WORDS_SALES=10
MAX_AGENT_WORDS_SAC_TROCA=15
MAX_AGENT_WORDS_SAC_ATRASO=15
MAX_AGENT_WORDS_INFO=6

# Limite maximo de palavras por mensagem do cliente virtual
MAX_CUSTOMER_WORDS_SALES=12
MAX_CUSTOMER_WORDS_SAC_TROCA=15
MAX_CUSTOMER_WORDS_SAC_ATRASO=20
MAX_CUSTOMER_WORDS_INFO=8

# Limite maximo de turnos por conversa (por intent)
MAX_TURNS_SALES=6
MAX_TURNS_SAC_TROCA=10
MAX_TURNS_SAC_ATRASO=15
MAX_TURNS_INFO=5

# ─── Configurações do Evaluator (Rubric V3) ───
# Máximo de palavras por mensagem do agente (para penalização por texto excessivo)
MAX_AGENT_WORDS=35

# Máximo de turnos simplificado (usado pelo evaluator)
MAX_TURNS_SALES=8
MAX_TURNS_SAC=10
MAX_TURNS_INFO=5

# ─── Template Engine (Sistema Híbrido Templates + LLM) ───
# Modo de operação:
# - "passive": apenas loga hits/misses, não altera comportamento
# - "active": usa templates para gerar respostas quando disponíveis
TEMPLATE_ENGINE_MODE=active

# Logging de métricas do template engine
# Defina como "false" para desativar logs em produção
TEMPLATE_LOG_HITS=true
TEMPLATE_LOG_MISSES=true

# ─── Human Loop (Transferência para Atendente Humano) ───
# ID do grupo WhatsApp para alertas de vendas (sem estoque)
WPP_GROUP_SALES_ID=""

# ID do grupo WhatsApp para alertas SAC
WPP_GROUP_SAC_ID=""

# Timezone do servidor para cálculo do fim do dia (padrão: America/Recife)
SERVER_TIMEZONE="America/Recife"

# ─── Ralph Loop — Calibração Automática ───────────────────────────────────────
# Ativar coleta de logs de interação (0=desligado, 1=ativo)
RALPH_LOGGING=0

# URL base do servidor Cadu para chamadas de avaliação
RALPH_WEBHOOK_URL=http://localhost:3001

# Modo de execução do loop (CHAT_ONLY | SHADOW | LEGACY)
RALPH_MODE=CHAT_ONLY

# Mínimo de pontos de melhoria para aceitar um patch (default: 5)
RALPH_MIN_IMPROVEMENT=5

# Máximo de iterações por execução do loop (default: 3)
RALPH_MAX_ITERATIONS=3
