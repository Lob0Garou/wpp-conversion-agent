{
  "name": "wpp-conversion-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3001",
    "dev:sandbox": "node scripts/dev-sandbox.js",
    "dev:sandbox:fast": "node scripts/dev-sandbox.js --skip-prisma",
    "dev:sandbox:chat": "node scripts/dev-sandbox-chat.js",
    "dev:tunnel": "node scripts/dev-tunnel.js",
    "dev:ssh": "node scripts/dev-ssh.js",
    "dev:all": "node scripts/dev-all.js",
    "dev:cf:app": "node scripts/dev-cf.js",
    "dev:cf:tunnel": "node scripts/dev-cf-tunnel.js",
    "dev:status": "node scripts/dev-status.js",
    "build": "next build",
    "build:sandbox": "npx prisma generate --schema=prisma/schema-sandbox.prisma && next build",
    "start": "next start",
    "start:sandbox": "node scripts/start-sandbox.js",
    "lint": "eslint",
    "prisma:sandbox:push": "node scripts/sync-sandbox-db.js",
    "prisma:sandbox:studio": "dotenv -e .env.sandbox -- npx prisma studio --schema=prisma/schema-sandbox.prisma",
    "export:wpp": "node scripts/export-wpp.js",
    "extract:openers": "tsx scripts/extract_openers.ts",
    "test": "jest",
    "test:harness": "tsx tests_harness/runner.ts",
    "feedback:analyze": "tsx scripts/feedback-cycle.ts analyze",
    "feedback:dry-run": "tsx scripts/feedback-cycle.ts dry-run",
    "feedback:apply": "tsx scripts/feedback-cycle.ts apply",
    "feedback:auto": "tsx scripts/feedback-cycle.ts apply --min-priority=70"
  },
  "dependencies": {
    "@langchain/core": "^1.1.28",
    "@langchain/langgraph": "^1.1.5",
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@langchain/openai": "^1.2.10",
    "@prisma/client": "^6.19.2",
    "@vercel/functions": "^3.4.2",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.6.2",
    "framer-motion": "^12.34.2",
    "libsignal-node": "^2.0.1",
    "lucide-react": "^0.574.0",
    "next": "16.1.6",
    "openai": "^6.22.0",
    "pg-boss": "^12.12.0",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "whatsapp-web.js": "^1.34.6",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "ngrok": "^5.0.0-beta.2",
    "postcss": "^8.5.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
