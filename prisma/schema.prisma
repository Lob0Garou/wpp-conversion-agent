generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Nota: pgvector deve ser instalado manualmente no PostgreSQL antes de ativar embeddings
  // extensions = [vector]  -- desabilitado até instalar pgvector no servidor
}

// ─── TELEMETRIA: tipos de evento para BI ───

enum TelemetryEventType {
  product_interest
  stock_check
  stock_result
  sale_outcome
  sac_case
  escalation
  sla_breach
}

// ─── QUEUE ROUTING: tipos de fila e prioridade ───

enum QueueType {
  SALES_RESERVE
  SAC_SUPPORT
}

enum Priority {
  NORMAL
  URGENT
}

// ─── MULTI-TENANT: todas as entidades possuem store_id ───

model Store {
  id              String   @id @default(uuid())
  name            String
  phoneNumber     String   @unique @map("phone_number")
  phoneNumberId   String   @unique @map("phone_number_id") // Meta phone_number_id → resolve store
  addressText     String?  @map("address_text")
  mapsUrl         String?  @map("maps_url")
  config          Json     @default("{}")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  customers        Customer[]
  conversations    Conversation[]
  messages         Message[]
  tickets          Ticket[]
  auditLogs        AuditLog[]
  products         Product[]
  telemetryEvents  TelemetryEvent[]
  reservations     Reservation[]
  saleEvents       SaleEvent[]
  inventoryImports InventoryImport[]
  memoryBank       MemoryBank[]

  @@map("stores")
}

model Product {
  id          String   @id @default(uuid())
  storeId     String   @map("store_id")
  sku         String?  @map("sku")          // Código do produto (ex: NK-PEG-42-M)
  description String
  price       Decimal? @map("price") @db.Decimal(10, 2) // Preço de venda (R$)
  quantity    Int

  // ─── CRM: campos de estoque estruturado ───
  brand      String?  @map("brand")
  groupName  String?  @map("group_name")
  size       String?  @map("size")
  importId   String?  @map("import_id")    // FK sem constraint (performance)

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Nota: campo embedding vector(1536) gerenciado via SQL manual (requer pgvector instalado)
  // embedding Unsupported("vector(1536)")?

  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@index([storeId])
  @@index([storeId, groupName])
  @@index([storeId, brand])
  @@map("products")
}

model Customer {
  id        String   @id @default(uuid())
  storeId   String   @map("store_id")
  phone     String
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  store         Store          @relation(fields: [storeId], references: [id])
  conversations Conversation[]
  tickets       Ticket[]
  reservations  Reservation[]

  @@unique([storeId, phone])
  @@index([storeId])
  @@map("customers")
}

model Conversation {
  id         String   @id @default(uuid())
  storeId    String   @map("store_id")
  customerId String   @map("customer_id")
  status     String   @default("open") // open | closed | escalated | PENDING_HUMAN
  startedAt  DateTime @default(now()) @map("started_at")
  closedAt   DateTime? @map("closed_at")

  // ─── HUMAN LOOP: status do bot para esta conversa ───
  // "BOT" = Cadu responde normalmente
  // "HUMAN" = Cadu ignorado até handoffUntil expirar
  botStatus  String   @default("BOT") @map("bot_status") // BOT | HUMAN
  handoffUntil DateTime? @map("handoff_until") // conversa travada até este horário

  // ─── ALERT RECORD: alerta enviado ao grupo de vendas ───
  alertSent  Json?    @map("alert_sent") // { type: 'SALE'|'SAC', sentAt: Date, messageId: string, groupId: string }

  // ─── LANGGRAPH STATE (Persistência Fase 5) ───
  langgraphState Json? @map("langgraph_state")

  // ─── SOURCE: tracking origin of conversation ───
  // Values: "manual" (default), "test_harness", "webhook", "api"
  source     String   @default("manual") @map("source")

  // ─── CRM ROUTING ───
  conversationType String @default("sales") @map("conversation_type") // sales | sac

  // ─── QUEUE ROUTING: fila de escalonamento atual ───
  currentQueue String? @map("current_queue") // SALES_RESERVE | SAC_SUPPORT | null

  // ─── STATE MACHINE ───
  currentState     String   @default("greeting") @map("current_state")
  // States: greeting | discovery | proposal | objection | closing | post_sale | support
  slots            Json     @default("{}") @map("slots")
  // Structure: { usage?, goal?, size?, product?, orderId? }
  messageCount     Int      @default(0) @map("message_count")
  stallCount       Int      @default(0) @map("stall_count")
  lastQuestionType String?  @map("last_question_type")
  frustrationLevel Int      @default(0) @map("frustration_level")
  // 0-3 scale: 0=normal, 1=slight, 2=moderate, 3=high (auto-escalate)

  // ─── CONCURRENCY LOCK ───
  processingUntil DateTime? @map("processing_until")
  // Set to now+TTL when processing; null when free. Prevents race conditions on rapid messages.

  store        Store         @relation(fields: [storeId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  messages     Message[]
  reservations Reservation[]

  @@index([storeId])
  @@index([storeId, status])
  @@index([storeId, currentState])
  @@index([storeId, conversationType])
  @@index([storeId, currentQueue])
  @@index([processingUntil])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  storeId        String   @map("store_id")
  conversationId String   @map("conversation_id")
  direction      String   // inbound | outbound
  content        String
  waMessageId    String   @map("wa_message_id") // idempotência: único por store
  timestamp      DateTime @default(now())
  metadata       Json?    @default("{}") // Store intent, risk, debug info

  store        Store        @relation(fields: [storeId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@unique([storeId, waMessageId]) // idempotência contra reenvio Meta
  @@index([storeId])
  @@index([conversationId])
  @@map("messages")
}

model Ticket {
  id             String   @id @default(uuid())
  storeId        String   @map("store_id")
  customerId     String   @map("customer_id")
  conversationId String?  @map("conversation_id") // link opcional à conversa de origem
  type           String   // sac | troca | garantia | duvida | reclamacao | reserva
  status         String   @default("open") // open | in_progress | closed
  notes          String?

  // ─── QUEUE ROUTING: campos de escalonamento ───
  queueType         QueueType? @map("queue_type")
  priority          Priority   @default(NORMAL) @map("priority")
  warmHandoffSummary String?   @map("warm_handoff_summary") @db.Text
  escalatedAt       DateTime?  @map("escalated_at")
  slaDeadline       DateTime?  @map("sla_deadline")
  slaBreached       Boolean    @default(false) @map("sla_breached")

  // ─── CRM: campos estruturados de atendimento ───
  email        String?
  cpf          String?
  orderId      String?  @map("order_id")
  ticketNumber String?  @unique @map("ticket_number")  // ex: SAC-0001
  category     String?  // troca | devolucao | garantia | duvida

  createdAt DateTime  @default(now()) @map("created_at")
  closedAt  DateTime? @map("closed_at")

  store    Store    @relation(fields: [storeId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([storeId])
  @@index([storeId, status])
  @@index([storeId, queueType])
  @@index([storeId, priority])
  @@index([storeId, conversationId])
  @@index([slaDeadline])
  @@map("tickets")
}

// ─── LOGGING DE AUDITORIA: cada decisão da Engine ───

model AuditLog {
  id        String   @id @default(uuid())
  storeId   String   @map("store_id")
  event     String   // ex: INTENT_CLASSIFIED, RISK_HIGH, HANDOFF, TICKET_CREATED
  intent    String?  // sales | stock | sac | human
  risk      String?  // low | medium | high
  action    String?  // ex: RESPOND, HANDOFF, CREATE_TICKET
  metadata  Json     @default("{}")
  timestamp DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([storeId, event])
  @@index([timestamp])
  @@map("audit_logs")
}

// ─── TELEMETRIA: eventos de demanda/estoque para BI ───

model TelemetryEvent {
  id             String             @id @default(uuid())
  storeId        String             @map("store_id")
  conversationId String             @map("conversation_id")
  customerId     String             @map("customer_id")      // SHA-256 do telefone (LGPD)
  requestId      String             @map("request_id")       // 1 UUID por ciclo de mensagem
  channel        String             @default("whatsapp")
  eventType      TelemetryEventType @map("event_type")
  payload        Json                                        // JSONB — estrutura varia por tipo
  eventKey       String             @unique @map("event_key") // hash(convId+reqId+eventType) — dedupe
  createdAt      DateTime           @default(now())          @map("created_at")

  store Store @relation(fields: [storeId], references: [id])

  @@index([eventType, createdAt])
  @@index([createdAt])
  @@index([storeId, eventType])
  @@index([requestId])
  @@map("telemetry_events")
}

// ─── CRM: Reserva de produto ───

model Reservation {
  id             String    @id @default(uuid())
  storeId        String    @map("store_id")
  customerId     String    @map("customer_id")
  conversationId String    @map("conversation_id")
  productId      String    @map("product_id")
  quantity       Int       @default(1)
  status         String    @default("active") // active | converted | expired | cancelled
  reservedAt     DateTime  @default(now()) @map("reserved_at")
  expiresAt      DateTime  @map("expires_at")     // mesmo dia 23:59 BRT
  convertedAt    DateTime? @map("converted_at")

  store        Store        @relation(fields: [storeId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])

  @@index([storeId, status])
  @@index([expiresAt])
  @@index([conversationId])
  @@map("reservations")
}

// ─── CRM: Evento de venda confirmada ───

model SaleEvent {
  id                 String   @id @default(uuid())
  storeId            String   @map("store_id")
  customerId         String   @map("customer_id")
  conversationId     String   @map("conversation_id")
  reservationId      String?  @map("reservation_id")  // optional link
  productDescription String   @map("product_description")
  productSku         String?  @map("product_sku")
  quantity           Int      @default(1)
  unitPrice          Decimal  @map("unit_price")  @db.Decimal(10, 2)
  totalPrice         Decimal  @map("total_price") @db.Decimal(10, 2)
  soldAt             DateTime @default(now()) @map("sold_at")

  store Store @relation(fields: [storeId], references: [id])

  @@index([storeId, soldAt])
  @@index([customerId])
  @@map("sale_events")
}

// ─── MEMORY BANK: Few-shot dinâmico por intenção ───
// Alimentado automaticamente pelo Evaluator quando score >= 90.
// Usado pelo prompt-system para injetar exemplos reais de sucesso.

model MemoryBank {
  id        String   @id @default(uuid())
  storeId   String?  @map("store_id")      // null = exemplo global (cross-store)
  intent    String                          // ex: SAC_ATRASO, SALES, OBJECTION
  userMsg   String   @map("user_msg")      // mensagem original do cliente
  agentMsg  String   @map("agent_msg")     // resposta exemplar do Cadu
  score     Float                          // nota LLM Judge (0-100)
  metadata  Json?                          // breakdown, feedback, state

  createdAt DateTime @default(now()) @map("created_at")

  store Store? @relation(fields: [storeId], references: [id])

  @@index([intent, score(sort: Desc)])
  @@index([storeId, intent])
  @@map("memory_bank")
}

// ─── FEEDBACK CYCLE: Lições aprendidas do ciclo de feedback ───
// Alimentado pelo PatternAnalyzer quando padrões de erro são identificados.
// Usado pelo PromptPatcher para gerar correções automáticas nos prompts.

model LearnedLesson {
  id              String   @id @default(uuid())
  
  // Origem da lição
  patternType     String   @map("pattern_type")    // repetition, escalation, etc.
  sourceTestIds   Json?    @map("source_test_ids") // IDs dos testes que geraram
  
  // Conteúdo da lição
  problem         String                          // Descrição do problema
  fixInstruction  String   @map("fix_instruction") // Instrução de correção
  
  // Aplicação
  targetIntent    String?  @map("target_intent")   // Intent afetada
  targetState     String?  @map("target_state")    // Estado afetado
  targetFile      String?  @map("target_file")     // Arquivo de prompt modificado
  
  // Métricas
  occurrences     Int      @default(1)             // Quantas vezes ocorreu
  severity        String   @default("medium")      // low, medium, high, critical
  status          String   @default("pending")     // pending, applied, validated, rejected
  
  // Auditoria
  createdAt       DateTime @default(now()) @map("created_at")
  appliedAt       DateTime? @map("applied_at")
  validatedAt     DateTime? @map("validated_at")
  
  @@index([patternType, status])
  @@index([status, createdAt])
  @@map("learned_lessons")
}

// ─── Evaluation Failures: Registro de falhas críticas ───
// Armazena avaliações com score < 50 para análise e debugging

model EvaluationFailure {
  id          String   @id @default(uuid())
  storeId     String?  @map("store_id")          // null = global
  intent      String
  userMsg     String   @map("user_msg")
  agentMsg    String   @map("agent_msg")
  score       Float
  breakdown   Json                            // {regras, tom, objetivo, concisao}
  feedback    String
  severity    String   @default("critical")   // always critical
  state       String?

  createdAt   DateTime @default(now()) @map("created_at")

  @@index([intent, score])
  @@index([storeId, intent])
  @@index([createdAt])
  @@map("evaluation_failures")
}

// ─── CRM: Importação de estoque via CSV (SNAPSHOT-BASED) ───
// O DB NÃO é source of truth — ele espelha o último snapshot ativo.
// Fluxo: parse → staging → validação → swap atômico.

enum ImportStatus {
  PENDING    // Em processamento
  ACTIVE     // Snapshot ativo atual (somente um por store)
  SUPERSEDED // Substituído por novo snapshot
  FAILED     // Falhou na validação
}

model InventoryImport {
  id          String       @id @default(uuid())
  storeId     String       @map("store_id")
  fileName    String       @map("file_name")
  totalRows   Int          @map("total_rows")
  validRows   Int          @map("valid_rows")
  invalidRows Int          @map("invalid_rows")
  errors      Json?        // Lista de erros por linha
  status      ImportStatus @default(PENDING) @map("status")
  importedAt  DateTime     @default(now()) @map("imported_at")
  supersededAt DateTime?   @map("superseded_at") // Quando foi substituído

  store Store @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([storeId, status])
  @@index([storeId, importedAt])
  @@map("inventory_imports")
}
